[settings]
color_theme = "dracula"
minimum_release_age = "2d"

[settings.github]
credential_command = "gh auth token"

[tools]
bat = "latest"
chezmoi = "latest"
delta = "latest"
eza = "latest"
fd = "latest"
fzf = "latest"
github-cli = "latest"
glow = "latest"
jq = "latest"
jsonschema = "latest"
herdr = "latest"
neovim = "latest"
ripgrep = "latest"
starship = "latest"
tree-sitter = "0.25.10"
yazi = "latest"
yq = "latest"
zoxide = "latest"
{{- range $key, $val := .chezmoidata.userlocal.mise.tools }}
"{{$key}}" = {{$val | toToml}}
{{- end }}


[tasks.post-install]
run = "nvim --headless '+Lazy! sync' +qa"


[shell_alias]

{{- range $key, $val := .chezmoidata.userlocal.mise.shell_alias }}
{{$key}} = {{$val | toToml}}
{{- end }}

################################################
# base utilities
################################################
l = "eza -l"
ls = "eza"
lt = "eza --tree"
tq = "yq -p toml"
y = "yazi"


################################################
# editor
################################################
v = "nvim"
vi = "nvim"
vim = "nvim"
view = "nvim -R"
vimdiff = "nvim -d%"


################################################
# chezmoi
################################################
cm = "chezmoi"
cmc = "cd {{.chezmoi.sourceDir}}"
cmd = "chezmoi diff"
cma = "chezmoi init --apply -v"
cmulu = "{{.chezmoi.homeDir}}/.local/share/chezmoi.userlocal/sync.sh"
cmulc = "cd {{.chezmoi.homeDir}}/.local/share/chezmoi.userlocal"
cmule = "nvim {{.chezmoi.homeDir}}/.local/share/chezmoi.userlocal/user/{{.chezmoi.username}}/{{.chezmoi.hostname}}/data.toml.tmpl"
cmhlc = "cd {{.chezmoi.homeDir}}/.local/share/chezmoi.hostlocal"
cmhle = "nvim {{.chezmoi.homeDir}}/.local/share/chezmoi.userlocal/host/{{.chezmoi.hostname}}/data.toml.tmpl"
cmu = "chezmoi update -v"
cmi = """() {(
  setopt LOCAL_OPTIONS ERREXIT
  cd {{.chezmoi.sourceDir}}
  local ignoreFile=".chezmoiignore"
  chezmoi unmanaged >> ${ignoreFile}
  LC_COLLATE=C LC_ALL=C sort -u -o ${ignoreFile} ${ignoreFile}
  git diff ${ignoreFile}
)}"""


################################################
# Package management
################################################
{{ if eq .chezmoi.os "darwin" -}}
# brew helper for mac (brew runs as a separate user)
brew = """() {
  case "$1" in
    install|update|upgrade|uninstall)
      echo "Switching user to ${BREWUSER} for brew..."
      sudo -i -u ${BREWUSER} sh -c "brew $*"
      ;;
    *)
      /opt/homebrew/bin/brew "$@"
      ;;
  esac
}"""
{{ end }}

# cross-platform native package update alias
pu = """() {(
  setopt LOCAL_OPTIONS ERREXIT XTRACE
{{ if eq .chezmoi.os "darwin" -}}
  sudo -i -u "${BREWUSER}" sh -c "HOMEBREW_NO_AUTO_UPDATE=0 NONINTERACTIVE=1 brew upgrade"
  {{ $configuredFile := joinPath .chezmoi.homeDir ".config/packages/brew.txt" }}
  installedFile="$(mktemp)"
  /opt/homebrew/bin/brew bundle dump --force --file="${installedFile}" --brews --casks --no-restart --no-describe
  sort -u -o ${installedFile} ${installedFile}
  hasDiff=false
  diff ${installedFile} {{$configuredFile}} || hasDiff=true
  if ${hasDiff}; then
    read -k 1 "REPLY?Apply brew diff? (y/N) "
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      sudo -i -u {{ template "brewuser.tmpl" . }} sh -c "brew bundle install --file={{ $configuredFile }} --force && brew bundle cleanup --file={{ $configuredFile }} --force"
    fi
  else
    echo "No brew diffs!"
  fi
{{- else if and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id") -}}
{{-   if (or (eq .chezmoi.osRelease.id "debian")
             (and (hasKey .chezmoi.osRelease "idLike")
	          (eq .chezmoi.osRelease.idLike "debian"))) -}}
  sudo -i bash -c "apt update -y && apt upgrade -y && apt autoremove -y"
{{-   else if eq .chezmoi.osRelease.id "arch" -}}
  sudo pacman -Suy
{{-   else -}}
{{- /* other Linux distro */ -}}
{{-   end -}}
{{- else -}}
{{- /* other OS */ -}}
{{- end }}
)}"""

mu = "mise upgrade -y && mise prune -y"

mpi = "mise run -s 'zsh -c' post-install"

u = "( cd {{.chezmoi.homeDir}}/.local/share/chezmoi && git pull && ./util/bootstrap.sh && cmu && pu && mu && mpi )"
