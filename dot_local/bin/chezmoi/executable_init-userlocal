#!/bin/bash

set -ex

DIR="chezmoi.userlocal"

cd ~/.local/share

if [ -d "${DIR}" ]; then
  echo "${DIR} already exists"
  exit 0
fi

[ "${USER}" ] || USER=$(whoami)
[ "${GITUSER}" ] || GITUSER="${USER}"
REPO="https://github.com/${GITUSER}/${DIR}"

if ! gh auth status; then
  gh auth login
fi

if ! gh repo view "${REPO}"; then
  echo "${REPO} does not exist"
  exit 0
fi

gh repo clone ${REPO}
exec ./${DIR}/sync.sh
